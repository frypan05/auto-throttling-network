{
  "uid": "nginx-lb-demo",
  "title": "Nginx Load Balancer — GraphQL Demo",
  "tags": ["nginx", "graphql", "load-balancing"],
  "style": "dark",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "🟢 Requests per Second (by Server)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "rate(app_graphql_requests_total[30s])",
          "legendFormat": "{{instance}} — {{query_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "🔥 Server Load % (Simulated CPU)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "app_server_load_percent",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "⏱  P95 Request Latency (by Server)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(instance, le) (rate(app_graphql_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p95 {{instance}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by(instance, le) (rate(app_graphql_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p50 {{instance}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "🔗 Active In-Flight Requests",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "app_active_requests",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "bars" }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "📊 Requests by Query Type (all servers)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "sum by(query_name) (rate(app_graphql_requests_total[30s]))",
          "legendFormat": "{{query_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "server-1 Load",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "app_server_load_percent{instance=\"server-1\"}",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "server-2 Load",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "app_server_load_percent{instance=\"server-2\"}",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "server-3 Load",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "app_server_load_percent{instance=\"server-3\"}",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "server-4 Load",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "app_server_load_percent{instance=\"server-4\"}",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Total Requests (last 5 min)",
      "gridPos": { "x": 0, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "sum(increase(app_graphql_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Avg P95 Latency (all servers)",
      "gridPos": { "x": 6, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "avg(histogram_quantile(0.95, sum by(instance, le) (rate(app_graphql_request_duration_seconds_bucket[1m]))))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1.0 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Max Server Load Right Now",
      "gridPos": { "x": 12, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "max(app_server_load_percent)",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Total Active Connections",
      "gridPos": { "x": 18, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "-- default --" },
      "targets": [
        {
          "expr": "sum(app_active_requests)",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    }
  ],
  "version": 1
}
